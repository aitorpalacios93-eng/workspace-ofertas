# WORKSPACE OFERTAS — Configuración de Credenciales
# Copia a .env y completa con tus valores reales
# NO HAGAS COMMIT DE .env — Git lo ignora automáticamente

# ─── CLAUDE / ANTHROPIC ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── TELEGRAM (notificaciones de feedback positivo) ────────────────
# Obtén bot_token: @BotFather en Telegram → /newbot
# Obtén chat_id: envía /start a tu bot, luego:
#   curl https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
#   y busca "chat":{"id": xxxxx}
WORKSPACE_TELEGRAM_BOT_TOKEN=
WORKSPACE_TELEGRAM_CHAT_ID=

# ─── DISCOVERY AUTOMÁTICA ────────────────────────────────────────
SERPAPI_KEY=

# ─── EMAIL FINDER (opcional pero recomendado) ─────────────────────
HUNTER_API_KEY=
APOLLO_API_KEY=

# ─── SUPABASE (opcional para escalar a muchos leads) ──────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── LOCAL SERVER ────────────────────────────────────────────────
WORKSPACE_PORT=8787
WORKSPACE_DEBUG=false
